#!/usr/bin/env bash
set -euo pipefail

# ANSI colors — check stderr, not stdout: stdout is reserved for directives
# (consumed by the shell wrapper), so all display output goes to stderr.
if [[ -t 2 ]]; then
  C_BOLD='\033[1m'; C_DIM='\033[2m'; C_RESET='\033[0m'
  C_RED='\033[31m'; C_GREEN='\033[32m'; C_YELLOW='\033[33m'; C_CYAN='\033[36m'
else
  C_BOLD=''; C_DIM=''; C_RESET=''
  C_RED=''; C_GREEN=''; C_YELLOW=''; C_CYAN=''
fi

usage() {
  # Write to stderr so stdout stays clean for the shell wrapper's directive capture.
  # Exit code is parameterised: 0 for --help (success), 1 for unknown command (error).
  cat >&2 << 'EOF'
Usage:
  wt new <name> [--cursor] [--code]   Create a worktree
  wt rm [--yes] [name]                Remove a worktree (default: current)
  wt cd <name>                        cd into an existing worktree
  wt ls                               List all worktrees
  wt init [name]                      Run init script for a worktree (default: current)
  wt clone <url> [name]               Bare clone + initial worktree, cd into it
  wt migrate                          Convert current regular repo to bare structure
  wt pr <github-pr-url>               Open a PR review worktree and launch Claude
  wt setup                            Install global post-checkout hook for branch tracking
  wt gc [--yes] [--wt <name>]         Delete local+remote branches for merged PRs
  wt branches                         Show branches grouped by originating worktree

Create options:
  --cursor    Open the worktree in Cursor
  --code      Open the worktree in VSCode
EOF
  exit "${1:-1}"
}

# Resolve git common dir to an absolute path from a given directory
resolve_common_dir() {
  local cwd="$1"
  local common_dir
  common_dir=$(git -C "$cwd" rev-parse --git-common-dir 2>/dev/null) || {
    echo "Error: not inside a git repository" >&2
    exit 1
  }
  # git returns --git-common-dir as a relative path (e.g. "../.git") for linked
  # worktrees. Resolve it to absolute by cd-ing from the worktree root.
  if [[ "$common_dir" != /* ]]; then
    common_dir="$(cd "$cwd" && cd "$common_dir" && pwd)"
  fi
  echo "$common_dir"
}

# Resolve repo root (bare repo dir, or parent of .git for regular repos)
resolve_repo_root() {
  local cwd="$1"
  local common_dir is_bare
  common_dir=$(resolve_common_dir "$cwd")
  is_bare=$(git --git-dir="$common_dir" rev-parse --is-bare-repository 2>/dev/null || echo "false")
  if [[ "$is_bare" == "true" ]]; then
    echo "$common_dir"
  else
    echo "$(dirname "$common_dir")"
  fi
}

# Resolve worktree target path from a name
resolve_target() {
  local name="$1"
  local cwd="$2"
  local common_dir is_bare

  common_dir=$(resolve_common_dir "$cwd")
  is_bare=$(git --git-dir="$common_dir" rev-parse --is-bare-repository 2>/dev/null || echo "false")

  if [[ "$is_bare" == "true" ]]; then
    # Bare repo: worktree is a sibling inside the bare repo dir
    echo "$common_dir/$name"
  else
    # Regular repo: worktree is a sibling at the parent level
    local repo_root
    repo_root="$(dirname "$common_dir")"
    echo "$(dirname "$repo_root")/$(basename "$repo_root")-$name"
  fi
}

# Returns: merged, open:<number>:<title>, none, or local-only
_branch_pr_status() {
  local COMMON_DIR="$1" branch="$2"
  local upstream gh_repo

  upstream=$(git --git-dir="$COMMON_DIR" for-each-ref \
    --format='%(upstream:short)' "refs/heads/$branch" 2>/dev/null || true)
  [[ -z "$upstream" ]] && echo "local-only" && return

  local remote="${upstream%%/*}"
  local remote_url
  remote_url=$(git --git-dir="$COMMON_DIR" remote get-url "$remote" 2>/dev/null || true)
  if [[ "$remote_url" =~ github\.com[:/]([^/]+)/([^/.]+)(\.git)?$ ]]; then
    gh_repo="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
  else
    echo "none"
    return
  fi

  # Check merged before open: most stale branches are merged, so this ordering
  # short-circuits the common case with one API call instead of two.
  # Fall back to "0" if gh fails (unauthenticated, network error) so we don't crash.
  local merged
  merged=$(gh pr list --repo "$gh_repo" --head "$branch" --state merged \
    --json number --jq 'length' 2>/dev/null || echo "0")
  if [[ "$merged" -gt 0 ]]; then echo "merged" && return; fi

  local open_pr
  open_pr=$(gh pr list --repo "$gh_repo" --head "$branch" --state open \
    --json number,title --jq '.[0] | "\(.number):\(.title)"' 2>/dev/null || true)
  if [[ -n "$open_pr" ]]; then echo "open:$open_pr" && return; fi

  echo "none"
}

# _do_delete_branches COMMON_DIR branch [branch ...]
_do_delete_branches() {
  local COMMON_DIR="$1"; shift
  for branch in "$@"; do
    # Save upstream BEFORE deleting the local branch — once the ref is gone
    # we can no longer look up what remote it tracked.
    local upstream
    upstream=$(git --git-dir="$COMMON_DIR" for-each-ref \
      --format='%(upstream:short)' "refs/heads/$branch" 2>/dev/null || true)

    printf "${C_BOLD}→ Deleting branch: %s${C_RESET}\n" "$branch" >&2
    # Use -D (force) because squash-merges leave the branch unmerged in git's
    # view — the commits were squashed, not actually merged, so -d would refuse.
    git --git-dir="$COMMON_DIR" branch -D "$branch" 1>&2 || true

    # Also delete remote tracking branch if one exists
    if [[ -n "$upstream" ]]; then
      local remote="${upstream%%/*}"
      local remote_branch="${upstream#*/}"
      git --git-dir="$COMMON_DIR" push "$remote" --delete "$remote_branch" 1>&2 || true
    fi
  done
}

# _gc_branches COMMON_DIR [WORKTREE_FILTER] [SKIP_PROMPTS]
# Collects stale branches, displays table, prompts for deletion.
_gc_branches() {
  local COMMON_DIR="$1"
  local WORKTREE_FILTER="${2:-}"
  local SKIP_PROMPTS="${3:-false}"
  local LOG="$COMMON_DIR/wt-branch-origin.tsv"

  # Collect active worktree paths and branches
  local ACTIVE_WTS ACTIVE_BRANCHES
  ACTIVE_WTS=$(git --git-dir="$COMMON_DIR" worktree list --porcelain \
    | awk '/^worktree / {print $2}')
  ACTIVE_BRANCHES=$(git --git-dir="$COMMON_DIR" worktree list --porcelain \
    | awk '/^branch / {b=$2; sub("refs/heads/","",b); print b}')

  # Grouping strategy: we want branches displayed under their originating worktree.
  # We can't use declare -A (associative arrays) because macOS ships bash 3.2 and
  # bats runs tests under it. Instead: one temp file per worktree (named by numeric
  # index), with wt_order[] as the ordered list of worktrees seen so far.
  local _gc_tmpdir
  _gc_tmpdir=$(mktemp -d)
  # shellcheck disable=SC2064
  trap "rm -rf '$_gc_tmpdir'" RETURN

  declare -a wt_order=()
  declare -a delete_queue=()
  local _gc_n=0  # count of unique worktrees seen

  # Find or create a numeric index for a worktree path; sets _gc_idx.
  # Linear scan is fine — the number of worktrees per repo is tiny.
  _gc_wt_index() {
    local _wt="$1"
    local _i
    for ((_i=0; _i<_gc_n; _i++)); do
      [[ "${wt_order[$_i]}" == "$_wt" ]] && { _gc_idx=$_i; return; }
    done
    wt_order[_gc_n]="$_wt"
    _gc_idx=$_gc_n
    _gc_n=$((_gc_n + 1))
  }

  if [[ -n "$WORKTREE_FILTER" ]]; then
    if [[ ! -f "$LOG" ]]; then
      echo "No tracked branches for this worktree (run 'wt setup' to enable tracking)." >&2
      return 0
    fi
    # Filter to branches from the specified worktree
    while IFS=$'\t' read -r branch worktree ts; do
      [[ "$worktree" != "$WORKTREE_FILTER" ]] && continue
      # Skip branches still active in a worktree
      if printf '%s\n' "$ACTIVE_BRANCHES" | grep -Fqx "$branch" 2>/dev/null; then
        continue
      fi
      local status_raw="" pr_info="" status_label=""
      status_raw=$(_branch_pr_status "$COMMON_DIR" "$branch")
      case "$status_raw" in
        merged)
          status_label="merged"
          delete_queue+=("$branch")
          ;;
        open:*)
          local pr_num="${status_raw#open:}" pr_title=""
          pr_title="${pr_num#*:}"
          pr_num="${pr_num%%:*}"
          status_label="open"
          pr_info="#$pr_num \"$pr_title\""
          ;;
        local-only)
          status_label="local-only"
          ;;
        *)
          status_label="none"
          ;;
      esac
      local _gc_idx=0
      _gc_wt_index "$worktree"
      printf '%s\t%s\t%s\n' "$branch" "$status_label" "$pr_info" >> "$_gc_tmpdir/$_gc_idx"
    done < "$LOG"
  else
    # Scan all local branches not in any active worktree
    local all_local_branches
    all_local_branches=$(git --git-dir="$COMMON_DIR" for-each-ref \
      --format='%(refname:short)' 'refs/heads/' 2>/dev/null || true)
    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      # Skip branches in active worktrees
      if printf '%s\n' "$ACTIVE_BRANCHES" | grep -Fqx "$branch" 2>/dev/null; then
        continue
      fi
      # Find originating worktree from log
      local origin_wt="unknown"
      if [[ -f "$LOG" ]]; then
        local found_wt
        found_wt=$(awk -F'\t' -v b="$branch" '$1==b {print $2; exit}' "$LOG" || true)
        [[ -n "$found_wt" ]] && origin_wt="$found_wt"
      fi

      local status_raw="" pr_info="" status_label=""
      status_raw=$(_branch_pr_status "$COMMON_DIR" "$branch")
      case "$status_raw" in
        merged)
          status_label="merged"
          delete_queue+=("$branch")
          ;;
        open:*)
          local pr_num="${status_raw#open:}" pr_title=""
          pr_title="${pr_num#*:}"
          pr_num="${pr_num%%:*}"
          status_label="open"
          pr_info="#$pr_num \"$pr_title\""
          ;;
        local-only)
          status_label="local-only"
          ;;
        *)
          status_label="none"
          ;;
      esac
      local _gc_idx=0
      _gc_wt_index "$origin_wt"
      printf '%s\t%s\t%s\n' "$branch" "$status_label" "$pr_info" >> "$_gc_tmpdir/$_gc_idx"
    done <<< "$all_local_branches"
  fi

  if [[ $_gc_n -eq 0 ]]; then
    echo "Nothing to delete." >&2
    return 0
  fi

  # Display table grouped by originating worktree
  local _i
  for ((_i=0; _i<_gc_n; _i++)); do
    local wt="${wt_order[$_i]}"
    local display_wt="${wt/#$HOME/~}"
    local wt_context="removed" ctx_color="$C_DIM"
    if printf '%s\n' "$ACTIVE_WTS" | grep -Fqx "$wt" 2>/dev/null; then
      wt_context="active"; ctx_color="$C_CYAN"
    fi

    printf "${C_BOLD}WORKTREE${C_RESET}  ${C_BOLD}%s${C_RESET}  ${ctx_color}[%s]${C_RESET}\n\n" \
      "$display_wt" "$wt_context" >&2
    printf "  %-20s  %-10s  %-24s  %s\n" "BRANCH" "STATUS" "PR" "ACTION" >&2
    printf "  %-20s  %-10s  %-24s  %s\n" \
      "──────────────────" "────────" "──────────────────────" "────────────" >&2

    [[ -f "$_gc_tmpdir/$_i" ]] && while IFS=$'\t' read -r branch status_label pr_info; do
      [[ -z "$branch" ]] && continue
      local action="" action_color="" status_color=""
      case "$status_label" in
        merged)
          status_color="$C_GREEN"; action="will delete"; action_color="$C_RED"
          ;;
        open)
          status_color="$C_YELLOW"
          ;;
        local-only | none)
          status_color="$C_DIM"
          ;;
      esac
      printf "  %-20s  ${status_color}%-10s${C_RESET}  %-24s  ${action_color}%s${C_RESET}\n" \
        "$branch" "$status_label" "$pr_info" "$action" >&2
    done < "$_gc_tmpdir/$_i"

    echo "" >&2
  done

  local delete_count=${#delete_queue[@]}
  if [[ "$delete_count" -eq 0 ]]; then
    echo "Nothing to delete." >&2
    return 0
  fi

  if [[ "$SKIP_PROMPTS" == "true" ]]; then
    _do_delete_branches "$COMMON_DIR" "${delete_queue[@]}"
  else
    printf "${C_YELLOW}%d branch(es) can be deleted. Delete? [y/N]${C_RESET} " \
      "$delete_count" >&2
    local answer
    # Read from /dev/tty directly: stdout is captured by the shell wrapper
    # (directive=$(command wt "$@")), so stdin may be a pipe, not the terminal.
    read -r answer </dev/tty
    if [[ "${answer,,}" == "y" ]]; then
      _do_delete_branches "$COMMON_DIR" "${delete_queue[@]}"
    else
      echo "Aborted." >&2
    fi
  fi
}

cmd_new() {
  local OPEN_CURSOR=false
  local OPEN_CODE=false
  local NAME=""

  for arg in "$@"; do
    case "$arg" in
      --cursor) OPEN_CURSOR=true ;;
      --code)   OPEN_CODE=true ;;
      --help|-h) usage 0 ;;
      -*) echo "Unknown option: $arg" >&2; usage ;;
      *) NAME="$arg" ;;
    esac
  done

  [[ -z "$NAME" ]] && usage

  local CWD TARGET
  CWD=$(pwd)
  TARGET=$(resolve_target "$NAME" "$CWD")

  if [[ -d "$TARGET" ]]; then
    echo "→ Worktree already exists: $TARGET" >&2
  else
    mkdir -p "$(dirname "$TARGET")"
    echo "→ Creating worktree: $TARGET" >&2
    # New branch preferred; fall back to existing branch with same name
    if ! git -C "$CWD" worktree add "$TARGET" -b "$NAME" >/dev/null 2>&1; then
      git -C "$CWD" worktree add "$TARGET" "$NAME" 1>&2
    fi
    echo "→ Created: $TARGET" >&2
  fi

  [[ "$OPEN_CURSOR" == "true" ]] && cursor "$TARGET"
  [[ "$OPEN_CODE"   == "true" ]] && code   "$TARGET"

  # stdout: directive consumed by the wt shell wrapper
  echo "cd+init:$TARGET"
}

cmd_ls() {
  local cwd current
  cwd=$(pwd)
  current=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || echo "")

  # Two-pass awk to align branch names in a column:
  # We can't know the longest path until all rows are read, so we buffer
  # everything in arrays during the first pass, then print with uniform
  # padding in END. Color codes are passed as -v variables so awk doesn't
  # need to know about ANSI escapes — they're just opaque strings.
  #
  # BEGIN { n = 0 }: BSD awk (macOS) initialises unset variables as ""
  # (empty string), not 0. Without explicit init, paths[n] on the first
  # iteration stores at paths[""] — a different slot from paths[0] — so the
  # first row silently disappears from the END loop.
  git -C "$cwd" worktree list --porcelain | awk \
    -v home="$HOME" -v current="$current" \
    -v bold="$C_BOLD" -v cyan="$C_CYAN" -v dim="$C_DIM" -v reset="$C_RESET" \
    '
    BEGIN { n = 0 }
    /^worktree / { path=$2; branch="" }
    /^branch /   { branch=$2; sub("refs/heads/", "", branch) }
    /^bare/      { path=""; branch="" }
    /^$/ {
      if (path != "") {
        display = path
        sub(home, "~", display)
        paths[n]    = display
        branches[n] = branch
        markers[n]  = (path == current) ? "*" : " "
        colors[n]   = (path == current) ? cyan : ""
        isdim[n]    = (branch == "") ? 1 : 0
        if (length(display) > maxlen) maxlen = length(display)
        n++
        path=""; branch=""
      }
    }
    END {
      fmt = "%-" maxlen "s"
      for (i = 0; i < n; i++) {
        padded = sprintf(fmt, paths[i])
        if (branches[i] != "")
          printf "%s%s %s%s%s [%s]%s\n", colors[i], markers[i], bold, padded, reset, branches[i], reset
        else
          printf "%s%s %s%s%s%s\n", dim, markers[i], bold, padded, reset, reset
      }
    }
  '
}

cmd_cd() {
  local NAME="${1:-}"
  [[ -z "$NAME" ]] && { echo "Usage: wt cd <name>"; exit 1; }

  local CWD TARGET
  CWD=$(pwd)
  TARGET=$(resolve_target "$NAME" "$CWD")

  if [[ ! -d "$TARGET" ]]; then
    echo "Error: worktree not found: $TARGET" >&2
    exit 1
  fi

  # stdout: directive consumed by the wt shell wrapper
  echo "cd:$TARGET"
}

cmd_remove() {
  local CWD TARGET SKIP_PROMPTS=false
  CWD=$(pwd)

  # Parse --yes/-y flag
  local ARGS=()
  for arg in "$@"; do
    case "$arg" in
      --yes|-y) SKIP_PROMPTS=true ;;
      *) ARGS+=("$arg") ;;
    esac
  done
  if [[ ${#ARGS[@]} -gt 0 ]]; then
    set -- "${ARGS[@]}"
  else
    set --
  fi

  if [[ -z "${1:-}" ]]; then
    # No arg: remove current worktree
    TARGET=$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null) || {
      echo "Error: not inside a worktree" >&2
      exit 1
    }
  else
    TARGET=$(resolve_target "$1" "$CWD")
  fi

  if [[ ! -d "$TARGET" ]]; then
    echo "Error: worktree not found: $TARGET" >&2
    exit 1
  fi

  # Determine where to cd after removal
  local COMMON_DIR IS_BARE DEST
  COMMON_DIR=$(resolve_common_dir "$CWD")
  IS_BARE=$(git --git-dir="$COMMON_DIR" rev-parse --is-bare-repository 2>/dev/null || echo "false")

  if [[ "$IS_BARE" == "true" ]]; then
    # Bare repo: cd to default branch worktree, not the bare root
    local DEFAULT_BRANCH
    DEFAULT_BRANCH=$(git --git-dir="$COMMON_DIR" symbolic-ref --short HEAD 2>/dev/null || echo "main")
    DEST="$COMMON_DIR/$DEFAULT_BRANCH"
    # If the default worktree is the one being removed, find another
    if [[ ! -d "$DEST" || "$DEST" == "$TARGET" ]]; then
      DEST=$(git --git-dir="$COMMON_DIR" worktree list --porcelain \
        | awk '/^worktree / {print $2}' \
        | grep -v "^$TARGET$" | grep -v "^$COMMON_DIR$" | head -1)
      [[ -z "$DEST" ]] && DEST="$COMMON_DIR"
    fi
  else
    # Regular repo: cd to the working copy root
    DEST=$(dirname "$COMMON_DIR")
  fi

  # Pre-removal warning check
  local BRANCH=""
  BRANCH=$(git -C "$TARGET" symbolic-ref --short HEAD 2>/dev/null || true)

  if [[ -n "$BRANCH" && "$SKIP_PROMPTS" == "false" ]]; then
    local warnings=()

    # Checked out in another worktree?
    local in_use
    in_use=$(git --git-dir="$COMMON_DIR" worktree list --porcelain | awk \
      -v branch="refs/heads/$BRANCH" -v target="$TARGET" '
      /^worktree / { wt=$2 }
      /^branch /   { if ($2==branch && wt != target) found++ }
      END           { print found+0 }
    ')
    [[ "${in_use:-0}" -gt 0 ]] && \
      warnings+=("branch '$BRANCH' is checked out in another worktree")

    # Local-only or open PR?
    local pr_status
    pr_status=$(_branch_pr_status "$COMMON_DIR" "$BRANCH")
    case "$pr_status" in
      local-only)
        warnings+=("branch '$BRANCH' has no remote tracking branch (local-only)")
        ;;
      open:*)
        local pr_info="${pr_status#open:}"
        local pr_num="${pr_info%%:*}"
        local pr_title="${pr_info#*:}"
        warnings+=("branch '$BRANCH' has an open PR: #$pr_num \"$pr_title\"")
        ;;
    esac

    if [[ ${#warnings[@]} -gt 0 ]]; then
      printf "${C_BOLD}Warning: removing worktree with active branch:${C_RESET}\n" >&2
      for w in "${warnings[@]}"; do
        printf "  ${C_YELLOW}!${C_RESET} %s\n" "$w" >&2
      done
      printf "Remove anyway? [y/N] " >&2
      local answer
      # /dev/tty: same reason as in _gc_branches — stdin may be a pipe.
    read -r answer </dev/tty
      if [[ "${answer,,}" != "y" ]]; then
        echo "Aborted." >&2
        exit 1
      fi
    fi
  fi

  echo "→ Removing worktree: $TARGET" >&2
  git -C "$CWD" worktree remove --force "$TARGET" 1>&2
  rm -rf "$TARGET"
  # Clean up the parent directory if it's now empty. For regular repos the
  # worktree is named like "myrepo-feat-x/" and the parent is shared with other
  # worktrees, so rmdir is a no-op unless this was the last one.
  rmdir "$(dirname "$TARGET")" 2>/dev/null || true
  echo "→ Removed: $TARGET" >&2

  # Post-removal gc: clean up branches from this worktree
  _gc_branches "$COMMON_DIR" "$TARGET" "$SKIP_PROMPTS"

  # stdout: directive consumed by the wt shell wrapper
  echo "rm:$TARGET:$DEST"
}

cmd_gc() {
  local SKIP_PROMPTS=false WORKTREE_FILTER=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) SKIP_PROMPTS=true ;;
      --wt)
        shift
        WORKTREE_FILTER=$(resolve_target "$1" "$(pwd)")
        ;;
      *)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
    esac
    shift
  done
  local CWD COMMON_DIR
  CWD=$(pwd)
  COMMON_DIR=$(resolve_common_dir "$CWD")
  _gc_branches "$COMMON_DIR" "$WORKTREE_FILTER" "$SKIP_PROMPTS"
}

cmd_branches() {
  local CWD COMMON_DIR
  CWD=$(pwd)
  COMMON_DIR=$(resolve_common_dir "$CWD")
  local LOG="$COMMON_DIR/wt-branch-origin.tsv"

  if [[ ! -f "$LOG" ]]; then
    echo "No branch tracking data. Run 'wt setup' to enable."
    exit 0
  fi

  # cmd_branches writes to stdout (not stderr), so check fd 1 for TTY.
  # The global C_* vars check fd 2; we need a separate set here so that
  # piping `wt branches | ...` strips colors correctly.
  local B="" D="" R="" GR="" YL="" CY=""
  if [[ -t 1 ]]; then
    B='\033[1m'; D='\033[2m'; R='\033[0m'
    GR='\033[32m'; YL='\033[33m'; CY='\033[36m'
  fi

  local WORKTREE_BRANCHES WORKTREE_PATHS
  WORKTREE_BRANCHES=$(git --git-dir="$COMMON_DIR" worktree list --porcelain \
    | awk '/^branch / {b=$2; sub("refs/heads/","",b); print b}')
  WORKTREE_PATHS=$(git --git-dir="$COMMON_DIR" worktree list --porcelain \
    | awk '/^worktree / {print $2}')

  # Same bash 3.2 grouping pattern as _gc_branches: temp files + indexed arrays.
  local _br_tmpdir
  _br_tmpdir=$(mktemp -d)
  # shellcheck disable=SC2064
  trap "rm -rf '$_br_tmpdir'" RETURN

  declare -a wt_order=()
  local _br_n=0

  # Find or create a numeric index for a worktree path; sets _br_idx.
  _br_wt_index() {
    local _wt="$1"
    local _i
    for ((_i=0; _i<_br_n; _i++)); do
      [[ "${wt_order[$_i]}" == "$_wt" ]] && { _br_idx=$_i; return; }
    done
    wt_order[_br_n]="$_wt"
    _br_idx=$_br_n
    _br_n=$((_br_n + 1))
  }

  while IFS=$'\t' read -r branch worktree ts; do
    local date_short="${ts%%T*}"
    local _br_idx=0
    _br_wt_index "$worktree"
    printf '%s\t%s\n' "$branch" "$date_short" >> "$_br_tmpdir/$_br_idx"
  done < "$LOG"

  local _i
  for ((_i=0; _i<_br_n; _i++)); do
    local wt="${wt_order[$_i]}"
    local display_wt="${wt/#$HOME/~}"
    local wt_context="removed" ctx_color="$D"
    if printf '%s\n' "$WORKTREE_PATHS" | grep -Fqx "$wt" 2>/dev/null; then
      wt_context="active"; ctx_color="$CY"
    fi

    printf "${B}WORKTREE${R}  ${B}%s${R}  ${ctx_color}[%s]${R}\n\n" "$display_wt" "$wt_context"
    printf "  %-20s  %-12s  %-12s  %s\n" "BRANCH" "DATE" "STATUS" "PR"
    printf "  %-20s  %-12s  %-12s  %s\n" \
      "──────────────────" "──────────" "──────────" "──────────────────────"

    [[ -f "$_br_tmpdir/$_i" ]] && while IFS=$'\t' read -r branch date_short; do
      [[ -z "$branch" ]] && continue
      local status_disp="" pr_info=""
      if printf '%s\n' "$WORKTREE_BRANCHES" | grep -Fqx "$branch" 2>/dev/null; then
        status_disp="${CY}active${R}"
      else
        local raw
        raw=$(_branch_pr_status "$COMMON_DIR" "$branch")
        case "$raw" in
          merged)
            status_disp="${GR}merged${R}"
            ;;
          open:*)
            local pr_num="${raw#open:}" pr_title=""
            pr_title="${pr_num#*:}"
            pr_num="${pr_num%%:*}"
            status_disp="${YL}open${R}"
            pr_info="#$pr_num \"$pr_title\""
            ;;
          local-only)
            status_disp="${D}local-only${R}"
            pr_info="—"
            ;;
          *)
            status_disp="${D}unknown${R}"
            ;;
        esac
      fi
      printf "  %-20s  %-12s  %-12b  %s\n" "$branch" "$date_short" "$status_disp" "$pr_info"
    done < "$_br_tmpdir/$_i"

    echo ""
  done
}

cmd_setup() {
  local HOOKS_DIR="$HOME/.config/wt/hooks"
  local HOOK_FILE="$HOOKS_DIR/post-checkout"

  mkdir -p "$HOOKS_DIR"

  cat > "$HOOK_FILE" << 'HOOK_EOF'
#!/usr/bin/env bash
# wt post-checkout hook: log new branch creations to wt-branch-origin.tsv

# git calls post-checkout with arg $3=1 for branch switches, $3=0 for file
# checkouts (e.g. git checkout -- file.txt). Skip file checkouts.
[[ "${3:-0}" != "1" ]] && exit 0

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

# Detect new branches by reflog depth: a just-created branch has exactly one
# entry (the creation commit). Switching back to an existing branch that has
# been committed to has more. We only want to log the worktree where the branch
# was *first* created, not every subsequent checkout.
REFLOG_COUNT=$(git reflog show "$BRANCH" 2>/dev/null | wc -l | tr -d ' ')
[[ "$REFLOG_COUNT" -gt 1 ]] && exit 0

WORKTREE=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null) || exit 0
# --git-common-dir is relative for linked worktrees; resolve to absolute.
if [[ "$COMMON_DIR" != /* ]]; then
  COMMON_DIR="$(cd "$WORKTREE" && cd "$COMMON_DIR" && pwd)"
fi

printf '%s\t%s\t%s\n' "$BRANCH" "$WORKTREE" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  >> "$COMMON_DIR/wt-branch-origin.tsv"

# Chain to any per-repo hook so we don't clobber existing hooks.
# exec rather than calling directly: preserves the hook's exit code as git's
# result and avoids spawning an extra process.
REPO_HOOK="${GIT_DIR}/hooks/post-checkout"
if [[ -x "$REPO_HOOK" ]]; then
  exec "$REPO_HOOK" "$@"
fi
HOOK_EOF

  chmod +x "$HOOK_FILE"
  # core.hooksPath redirects git's hook lookup to a single shared directory,
  # so we install once globally rather than per-repo.
  git config --global core.hooksPath "$HOOKS_DIR"
  echo "→ Installed hook: $HOOK_FILE" >&2
  echo "→ Set git config core.hooksPath = $HOOKS_DIR" >&2
  echo "→ Branch tracking is now active for all repos." >&2
}

cmd_clone() {
  local URL="${1:-}"
  [[ -z "$URL" ]] && { echo "Usage: wt clone <url> [name]"; exit 1; }

  # Derive repo name from URL if not provided
  local NAME="${2:-}"
  if [[ -z "$NAME" ]]; then
    NAME=$(basename "$URL" .git)
  fi

  local BARE_DIR
  BARE_DIR="$(pwd)/$NAME"

  if [[ -d "$BARE_DIR" ]]; then
    echo "Error: directory already exists: $BARE_DIR" >&2
    exit 1
  fi

  echo "→ Cloning $URL → $BARE_DIR" >&2
  git clone --bare --ref-format=reftable "$URL" "$BARE_DIR" 1>&2

  # Detect default branch
  local DEFAULT_BRANCH
  DEFAULT_BRANCH=$(git -C "$BARE_DIR" symbolic-ref --short HEAD 2>/dev/null || echo "main")

  # Create initial worktree for the default branch
  local WORKTREE="$BARE_DIR/$DEFAULT_BRANCH"
  echo "→ Creating worktree: $WORKTREE" >&2
  git -C "$BARE_DIR" worktree add "$WORKTREE" "$DEFAULT_BRANCH" 1>&2
  git -C "$WORKTREE" branch --set-upstream-to="origin/$DEFAULT_BRANCH" "$DEFAULT_BRANCH" 1>&2
  echo "→ Done: $WORKTREE" >&2

  # stdout: directive consumed by the wt shell wrapper
  echo "cd+init:$WORKTREE"
}

cmd_pr() {
  local URL="${1:-}"
  [[ -z "$URL" ]] && { echo "Usage: wt pr <github-pr-url>"; exit 1; }

  # Parse GitHub PR URL: https://github.com/ORG/REPO/pull/NUMBER
  local ORG REPO PR_NUMBER
  if [[ "$URL" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
    ORG="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
    PR_NUMBER="${BASH_REMATCH[3]}"
  else
    echo "Error: invalid GitHub PR URL: $URL" >&2
    exit 1
  fi

  # Find local repo by matching remote URL against ~/Projects dirs
  local REPO_DIR=""
  echo "→ Searching ~/Projects for $ORG/$REPO..." >&2
  for dir in "$HOME/Projects"/*/; do
    [[ -d "$dir" ]] || continue
    local remote
    remote=$(git -C "$dir" remote get-url origin 2>/dev/null || true)
    if echo "$remote" | grep -q "$ORG/$REPO"; then
      REPO_DIR="${dir%/}"
      break
    fi
  done

  # If not found locally, auto-clone using gh to get the SSH URL
  if [[ -z "$REPO_DIR" ]]; then
    echo "→ Not found — resolving SSH URL via gh..." >&2
    local CLONE_URL
    CLONE_URL=$(gh repo view "$ORG/$REPO" --json sshUrl -q '.sshUrl' 2>/dev/null) || {
      echo "Error: could not resolve $ORG/$REPO via gh. Is gh authenticated?" >&2
      exit 1
    }
    local BARE_DIR="$HOME/Projects/$REPO"
    echo "→ Cloning $CLONE_URL → $BARE_DIR" >&2
    git clone --bare --ref-format=reftable "$CLONE_URL" "$BARE_DIR" 1>&2
    local DEFAULT_BRANCH
    DEFAULT_BRANCH=$(git -C "$BARE_DIR" symbolic-ref --short HEAD 2>/dev/null || echo "main")
    local INITIAL_WORKTREE="$BARE_DIR/$DEFAULT_BRANCH"
    echo "→ Creating initial worktree: $INITIAL_WORKTREE" >&2
    git -C "$BARE_DIR" worktree add "$INITIAL_WORKTREE" "$DEFAULT_BRANCH" 1>&2
    git -C "$INITIAL_WORKTREE" branch --set-upstream-to="origin/$DEFAULT_BRANCH" "$DEFAULT_BRANCH" 1>&2
    REPO_DIR="$BARE_DIR"
  else
    echo "→ Found: $REPO_DIR" >&2
  fi

  # Create a detached worktree named pr-<number>
  # review-pr uses `gh pr checkout` to set up the branch — no local branch needed here
  local NAME="pr-$PR_NUMBER"
  local TARGET
  TARGET=$(resolve_target "$NAME" "$REPO_DIR")

  if [[ -d "$TARGET" ]]; then
    echo "→ Reusing existing worktree: $TARGET" >&2
  else
    mkdir -p "$(dirname "$TARGET")"
    echo "→ Fetching origin..." >&2
    git -C "$REPO_DIR" fetch origin 1>&2
    echo "→ Creating detached worktree: $TARGET" >&2
    git -C "$REPO_DIR" worktree add --detach "$TARGET" 1>&2
    echo "→ Done: $TARGET" >&2
  fi

  # Use | as separator since URLs contain colons
  # stdout: directive consumed by the wt shell wrapper (pr: → no init)
  echo "pr:$TARGET|$URL"
}

cmd_migrate() {
  local CWD COMMON_DIR IS_BARE
  CWD=$(pwd)
  COMMON_DIR=$(resolve_common_dir "$CWD")
  IS_BARE=$(git --git-dir="$COMMON_DIR" rev-parse --is-bare-repository 2>/dev/null || echo "false")

  if [[ "$IS_BARE" == "true" ]]; then
    echo "Error: already a bare repo" >&2
    exit 1
  fi

  local REPO_ROOT NAME PARENT BAK BARE_TMP DEFAULT_BRANCH WORKTREE
  REPO_ROOT="$(dirname "$COMMON_DIR")"
  NAME=$(basename "$REPO_ROOT")
  PARENT=$(dirname "$REPO_ROOT")
  BAK="$REPO_ROOT-bak"
  BARE_TMP="$PARENT/$NAME-bare-tmp"

  # Capture sibling worktrees (path:branch) before migration
  local SIBLINGS
  SIBLINGS=$(git -C "$REPO_ROOT" worktree list --porcelain | awk -v main="$REPO_ROOT" '
    /^worktree / { path=$2; branch="" }
    /^branch /   { branch=$2; sub("refs/heads/", "", branch) }
    /^$/ && path != main && branch != "" { print path ":" branch }
  ')

  # Capture remote URLs before migration
  local REMOTE_URL
  REMOTE_URL=$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)

  echo "→ Cloning bare repo to $BARE_TMP..." >&2
  git clone --bare --ref-format=reftable "$REPO_ROOT/.git" "$BARE_TMP" 1>&2
  echo "→ Replacing $REPO_ROOT with bare clone..." >&2
  mv "$REPO_ROOT" "$BAK"
  mv "$BARE_TMP" "$REPO_ROOT"

  # Fix remote: bare clone points to local path, not the original upstream
  if [[ -n "$REMOTE_URL" ]]; then
    echo "→ Restoring remote origin → $REMOTE_URL" >&2
    git -C "$REPO_ROOT" remote set-url origin "$REMOTE_URL"
    git -C "$REPO_ROOT" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
    echo "→ Fetching from origin..." >&2
    git -C "$REPO_ROOT" fetch 1>&2
  fi

  # Create main worktree
  DEFAULT_BRANCH=$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo "main")
  WORKTREE="$REPO_ROOT/$DEFAULT_BRANCH"
  echo "→ Creating main worktree: $WORKTREE" >&2
  git -C "$REPO_ROOT" worktree add "$WORKTREE" "$DEFAULT_BRANCH" 1>&2
  git -C "$WORKTREE" branch --set-upstream-to="origin/$DEFAULT_BRANCH" "$DEFAULT_BRANCH" 1>&2

  # Move sibling worktrees inside the bare repo and re-register them
  if [[ -n "$SIBLINGS" ]]; then
    while IFS=: read -r OLD_PATH BRANCH; do
      [[ -z "$OLD_PATH" ]] && continue
      local SAFE_BRANCH NEW_PATH
      SAFE_BRANCH="${BRANCH//\//-}"
      NEW_PATH="$REPO_ROOT/$SAFE_BRANCH"
      echo "Moving worktree: $OLD_PATH → $NEW_PATH" >&2
      mv "$OLD_PATH" "$NEW_PATH"
      git -C "$REPO_ROOT" worktree repair "$NEW_PATH" >&2
    done <<< "$SIBLINGS"
  fi

  echo "→ Done. Verify '$WORKTREE' works, then remove the backup:" >&2
  echo "   rm -rf '$BAK'" >&2

  # stdout: directive consumed by the wt shell wrapper
  echo "cd+init:$WORKTREE"
}

# Dispatch — guarded so `source bin/wt` in tests loads functions without
# executing cmd_ls (the default for empty args).
if [[ -z "${__WT_TESTS:-}" ]]; then
  case "${1:-}" in
    new)      shift; cmd_new "$@" ;;
    rm)       shift; cmd_remove "$@" ;;
    cd)       shift; cmd_cd "$@" ;;
    ls)       cmd_ls ;;
    clone)    shift; cmd_clone "$@" ;;
    migrate)  cmd_migrate ;;
    pr)       shift; cmd_pr "$@" ;;
    setup)    cmd_setup ;;
    gc)       shift; cmd_gc "$@" ;;
    branches) cmd_branches ;;
    --help|-h) usage 0 ;;
    "")       cmd_ls; echo; echo "Run 'wt --help' for usage." ;;
    *)        echo "Unknown command: ${1}." >&2; usage 1 ;;
  esac
fi
